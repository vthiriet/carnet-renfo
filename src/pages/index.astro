<!doctype html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1">
<title>Carnet Renfo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style is:global>
  :root{
    --bg: #17140f;
    --panel: #221d16;
    --panel-2: #2b241a;
    --line: #3a3226;
    --text: #f1ece1;
    --muted: #948a76;
    --brass: #c99a3e;
    --brass-dim: #7a5f28;
    --phase-meca: #6f8fa8;
    --phase-meta: #b3763f;
    --phase-over: #c15b3c;
    --ok: #7fa06a;
    --m-pecs: #c97a4e;
    --m-bras: #6f9c8f;
    --m-abdos: #9e8fc9;
    --m-dos: #c96f8f;
  }
  *{ box-sizing: border-box; }
  html,body{
    margin:0; padding:0;
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    -webkit-font-smoothing: antialiased;
  }
  body{
    min-height:100vh;
    padding: 20px 14px 60px;
    max-width: 480px;
    margin: 0 auto;
  }
  h1,h2,h3{
    font-family:'Oswald', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin:0;
  }
  .num{
    font-family:'JetBrains Mono', monospace;
    font-variant-numeric: tabular-nums;
  }
  header.top{
    display:flex; align-items:baseline; justify-content:space-between;
    margin-bottom:18px;
  }
  header.top h1{ font-size: 20px; font-weight:700; color: var(--text); }
  header.top .tag{ font-size:11px; color:var(--brass); letter-spacing:0.12em; font-family:'Oswald',sans-serif; }
  .settings-btn{
    background:none; border:1px solid var(--line); color:var(--muted);
    font-size:11px; padding:5px 9px; border-radius:6px; cursor:pointer;
    font-family:'Inter',sans-serif;
  }
  .settings-btn:active{ background: var(--panel-2); }

  .card{
    background: var(--panel);
    border:1px solid var(--line);
    border-radius:10px;
    padding:18px;
    margin-bottom:14px;
  }
  .card p{ color:var(--muted); font-size:13px; line-height:1.5; margin:6px 0 14px; }
  label{ display:block; font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px; }
  input[type=number]{
    width:100%; background:var(--bg); border:1px solid var(--line);
    color:var(--text); border-radius:7px; padding:10px 12px;
    font-family:'JetBrains Mono', monospace; font-size:15px;
  }
  input:focus{ outline:2px solid var(--brass); outline-offset:1px; }
  button.primary{
    width:100%; background:var(--brass); color:#1a1508; border:none;
    font-family:'Oswald',sans-serif; text-transform:uppercase; letter-spacing:0.05em;
    font-weight:600; font-size:14px; padding:12px; border-radius:8px; margin-top:12px;
    cursor:pointer;
  }
  button.primary:active{ background:#b3872f; }
  button.ghost{
    width:100%; background:transparent; color:var(--muted); border:1px solid var(--line);
    font-family:'Inter',sans-serif; font-size:12px; padding:9px; border-radius:8px; margin-top:8px;
    cursor:pointer;
  }
  button.ghost:active{ background:var(--panel-2); }

  /* Position dashboard */
  .position-card{ padding:16px 16px 18px; }
  .meso-index{ font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em; }
  .meso-phase{ font-size:15px; font-weight:600; margin-top:2px; margin-bottom:14px; }
  .position-top{ display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:14px; }
  .week-label{ font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em; }
  .week-num{ font-size:30px; font-weight:700; line-height:1; }
  .week-sub{ font-size:11px; color:var(--muted); margin-top:2px; }

  .bar{ display:flex; gap:2px; margin: 10px 0 8px; }
  .bar .seg{ flex:1; height:10px; border-radius:2px; background:var(--line); }
  .bar .seg.meca{ background: var(--phase-meca); opacity:0.35; }
  .bar .seg.meta{ background: var(--phase-meta); opacity:0.35; }
  .bar .seg.over{ background: var(--phase-over); opacity:0.35; }
  .bar .seg.done{ opacity:0.9 !important; }
  .bar .seg.current{ outline:2px solid var(--text); outline-offset:1px; opacity:1 !important; }
  .bar-meta{ display:flex; justify-content:space-between; font-size:10px; color:var(--muted); margin-bottom:14px; }

  .micro-info{
    display:flex; gap:10px; background:var(--panel-2); border-radius:8px; padding:10px 12px;
    align-items:center;
  }
  .micro-dot{ width:9px; height:9px; border-radius:50%; flex-shrink:0; }
  .micro-dot.meca{ background:var(--phase-meca); }
  .micro-dot.meta{ background:var(--phase-meta); }
  .micro-dot.over{ background:var(--phase-over); }
  .micro-text .n{ font-size:13px; font-weight:600; }
  .micro-text .d{ font-size:12px; color:var(--muted); }
  .micro-note{ font-size:11px; color:var(--brass); margin-top:6px; line-height:1.4; }

  .next-banner{
    display:flex; align-items:center; justify-content:space-between;
    background: var(--panel-2); border:1px solid var(--brass-dim); border-radius:9px;
    padding:12px 14px; margin: 14px 0 10px;
  }
  .next-banner .lbl{ font-size:10px; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em; }
  .next-banner .val{ font-family:'Oswald',sans-serif; font-size:20px; font-weight:700; color:var(--brass); }
  .next-duration{ font-size:11px; color:var(--muted); margin-top:3px; }

  .ex-card{
    background:var(--panel); border:1px solid var(--line); border-radius:10px;
    padding:14px; margin-bottom:10px;
  }
  .ex-head{ display:flex; justify-content:space-between; align-items:flex-start; gap:8px; }
  .ex-name{ font-size:14.5px; font-weight:600; line-height:1.3; }
  .ex-target{
    flex-shrink:0; text-align:right; font-family:'JetBrains Mono',monospace;
    font-size:11px; color:var(--brass); white-space:nowrap;
  }
  .ex-sets-counter{ display:block; margin-top:4px; color:var(--text); font-weight:700; }

  .ex-meta-row{ display:flex; align-items:center; gap:8px; margin-top:5px; }
  .ex-muscle{
    display:inline-flex; align-items:center; font-family:'Oswald',sans-serif;
    font-size:9.5px; font-weight:600; text-transform:uppercase; letter-spacing:0.07em;
    padding:8px 10px; border-radius:20px; line-height:1;
  }
  .ex-muscle.pecs{ background:rgba(201,122,78,0.18); color:var(--m-pecs); }
  .ex-muscle.bras{ background:rgba(111,156,143,0.18); color:var(--m-bras); }
  .ex-muscle.abdos{ background:rgba(158,143,201,0.18); color:var(--m-abdos); }
  .ex-muscle.dos{ background:rgba(201,111,143,0.18); color:var(--m-dos); }
  .ex-inputs{ display:flex; gap:8px; margin-top:10px; }
  .ex-inputs .field{ flex:1; }
  .ex-inputs input{ padding:9px 10px; font-size:14px; }
  .ex-save{
    background:var(--panel-2); border:1px solid var(--line); color:var(--text);
    border-radius:7px; padding:9px 14px; font-family:'Oswald',sans-serif;
    font-size:13px; font-weight:600; letter-spacing:0.03em; cursor:pointer;
    white-space:nowrap;
  }
  .ex-save:active{ background:var(--brass-dim); }
  .ex-saved-flash{ font-size:11px; color:var(--ok); margin-top:6px; display:none; }
  .ex-error-flash{ font-size:11px; color:var(--phase-over); margin-top:6px; display:none; }

  .validate-btn{
    width:100%; background: var(--ok); color:#12200e; border:none;
    font-family:'Oswald',sans-serif; text-transform:uppercase; letter-spacing:0.05em;
    font-weight:700; font-size:15px; padding:14px; border-radius:9px; margin: 6px 0 4px;
    cursor:pointer;
  }
  .validate-btn:active{ background:#6c8a5a; }
  .validate-sub{ text-align:center; font-size:11px; color:var(--muted); margin-bottom:14px; }

  .settings-row{ display:flex; gap:8px; align-items:flex-end; margin-bottom:6px; }
  .settings-row .field{ flex:1; }
  .undo-row{ margin-top:10px; }

  .done-banner{ text-align:center; padding:30px 10px; }
  .done-banner .n{ font-size:15px; font-weight:600; color:var(--brass); font-family:'Oswald',sans-serif; }

  .footer-note{ font-size:11px; color:var(--muted); text-align:center; margin-top:22px; line-height:1.5; }
  .hidden{ display:none !important; }

  .rest-timer{
    position:fixed; left:0; right:0; bottom:0;
    background: var(--brass); color:#1a1508;
    padding:14px 16px; display:flex; align-items:center; justify-content:space-between;
    box-shadow: 0 -4px 16px rgba(0,0,0,0.35);
    z-index: 50;
  }
  .rest-timer .rest-label{ font-family:'Oswald',sans-serif; font-size:11px; text-transform:uppercase; letter-spacing:0.08em; opacity:0.8; }
  .rest-timer .rest-time{ font-family:'JetBrains Mono',monospace; font-size:26px; font-weight:700; font-variant-numeric: tabular-nums; }
  .rest-skip{
    background:#1a1508; color:var(--brass); border:none; border-radius:7px;
    padding:9px 14px; font-family:'Oswald',sans-serif; font-size:13px; font-weight:600;
    letter-spacing:0.03em; cursor:pointer;
  }

  .ex-info-btn{
    background:none; border:1px solid var(--line); color:var(--muted); border-radius:20px;
    font-size:11px; line-height:1; cursor:pointer;
    display:inline-flex; align-items:center; justify-content:center; vertical-align:middle;
    padding:9px 12px; font-family:'Inter',sans-serif; letter-spacing:0.03em;
  }
  .ex-info-btn:active{ background:var(--panel-2); }

  .info-overlay{
    position:fixed; inset:0; background:rgba(0,0,0,0.6);
    display:flex; align-items:flex-end; justify-content:center;
    z-index:100;
  }
  .info-sheet{
    background:var(--panel); border:1px solid var(--line); border-bottom:none;
    border-top-left-radius:16px; border-top-right-radius:16px;
    width:100%; max-width:480px; max-height:75vh; overflow-y:auto;
    padding:18px 18px 26px;
  }
  .info-sheet-head{ display:flex; justify-content:space-between; align-items:center; margin-bottom:14px; gap:10px; }
  .info-sheet-title{ font-family:'Oswald',sans-serif; font-size:16px; font-weight:600; text-transform:uppercase; letter-spacing:0.03em; }
  .info-close{ background:none; border:none; color:var(--muted); font-size:20px; line-height:1; cursor:pointer; padding:4px 6px; flex-shrink:0; }
  .info-video-link{
    display:inline-block; margin-bottom:12px; color:var(--brass); font-size:13px;
    text-decoration:none; border:1px solid var(--brass-dim); border-radius:7px; padding:8px 12px;
  }
  .info-steps{ margin:0 0 4px; padding-left:20px; color:var(--text); font-size:13px; line-height:1.6; }
  .info-variant-name{
    font-family:'Oswald',sans-serif; font-size:12px; color:var(--brass);
    text-transform:uppercase; letter-spacing:0.05em; margin:16px 0 8px;
  }
  .info-variant-name:first-child{ margin-top:0; }
</style>
</head>
<body>

<header class="top">
  <div>
    <h1>Carnet Renfo</h1>
    <div class="tag">MACROCYCLE : PECS · BRAS · ABDOS</div>
  </div>
  <button class="settings-btn" id="settingsBtn">Réglages</button>
</header>

<div id="settingsPanel" class="card hidden">
  <h3 style="font-size:14px;">Réglages du compteur</h3>
  <p>Le programme avance uniquement quand tu valides une séance — aucune date n'entre en jeu, donc rater une semaine ne décale rien.</p>
  <div class="settings-row">
    <div class="field">
      <label for="manualCount">Séances déjà validées</label>
      <input type="number" id="manualCount" min="0" max="72">
    </div>
  </div>
  <button class="primary" id="saveCountBtn">Enregistrer</button>
  <div class="undo-row">
    <button class="ghost" id="undoBtn">Annuler la dernière séance validée</button>
  </div>
  <button class="ghost" id="closeSettingsBtn">Fermer</button>
</div>

<div id="mainApp">

  <div class="card position-card">
    <div class="meso-index" id="mesoIndex">Mésocycle —</div>
    <div class="meso-phase" id="mesoPhase">— — Semaines —</div>

    <div class="position-top">
      <div>
        <div class="week-label">Semaine</div>
        <div class="week-num num" id="weekNum">—</div>
        <div class="week-sub num" id="sessionCount">—</div>
      </div>
    </div>

    <div class="bar" id="weekBar"></div>
    <div class="bar-meta"><span>S1</span><span>S8</span><span>S16</span><span>S24</span></div>

    <div class="micro-info">
      <div class="micro-dot" id="microDot"></div>
      <div class="micro-text">
        <div class="n">Microcycle : <span id="microName">—</span> <button type="button" id="microInfoBtn" class="ex-info-btn">ⓘ Infos</button></div>
        <div class="d" id="microDetail">—</div>
      </div>
    </div>
    <div class="micro-note" id="microNote"></div>
  </div>

  <div id="activeZone">
    <div class="next-banner">
      <div>
        <div class="lbl">Prochaine séance</div>
        <div class="val" id="nextSeanceLabel">—</div>
        <div class="next-duration" id="nextSeanceDuration"></div>
      </div>
    </div>

    <div id="exList"></div>

    <button class="validate-btn" id="validateBtn">✓ Séance validée — passer à la suivante</button>
    <div class="validate-sub">Fait avancer le compteur d'une séance (A → B → C → A…)</div>
  </div>

  <div id="macroDone" class="card done-banner hidden">
    <div class="n">Macrocycle terminé — 72/72 séances</div>
    <p>C'est le moment de réévaluer objectifs et programme pour la suite.</p>
  </div>

</div>

<div class="footer-note">Reps/repos affichés = ceux du microcycle en cours.<br>Dernière charge affichée sous chaque exercice.</div>

<div id="restTimer" class="rest-timer hidden">
  <div>
    <div class="rest-label">Repos</div>
    <div class="rest-time" id="restTimeLeft">--:--</div>
  </div>
  <button class="rest-skip" id="restSkipBtn">Passer</button>
</div>

<div id="exerciseInfoOverlay" class="info-overlay hidden">
  <div class="info-sheet">
    <div class="info-sheet-head">
      <div class="info-sheet-title" id="infoSheetTitle"></div>
      <button class="info-close" id="infoCloseBtn" aria-label="Fermer">✕</button>
    </div>
    <div id="infoSheetBody"></div>
  </div>
</div>

<script>
import { supabase } from '../lib/supabase';

const PROGRAM = [
  { name:"Force", start:1, end:8, micro:[
    { key:"meca", name:"Stress mécanique", w:[1,3], reps:"6-8", rest:"2 min 30", note:"" },
    { key:"meta", name:"Consolidation", w:[4,6], reps:"4-6", rest:"3 min", note:"" },
    { key:"over", name:"Overreaching", w:[7,8], reps:"4-6", rest:"3 min", note:"+1 série sur les mouvements principaux · rest-pause sur le dernier exercice · deload optionnel les 2-3 derniers jours si besoin" }
  ]},
  { name:"Prise de muscle", start:9, end:16, micro:[
    { key:"meca", name:"Stress mécanique", w:[9,11], reps:"8-10", rest:"1 min 45", note:"" },
    { key:"meta", name:"Stress métabolique", w:[12,14], reps:"10-15", rest:"1 min", note:"" },
    { key:"over", name:"Overreaching", w:[15,16], reps:"10-15", rest:"1 min", note:"+1 série · superset/drop set sur 1-2 exercices · deload optionnel les 2-3 derniers jours si besoin" }
  ]},
  { name:"Perte de gras", start:17, end:24, micro:[
    { key:"meca", name:"Densité — phase 1", w:[17,19], reps:"10-15", rest:"1 min", note:"" },
    { key:"meta", name:"Densité — phase 2", w:[20,22], reps:"10-15", rest:"45 sec", note:"" },
    { key:"over", name:"Densité maximale", w:[23,24], reps:"10-15", rest:"40 sec", note:"Fin de macrocycle — pas de deload nécessaire, moment de réévaluer le programme" }
  ]}
];

const SEANCES = {
  A: { label:"Séance A : Pecs + Abdos", ex:[
    "Développé légèrement décliné",
    "Écarté poulie vis-à-vis, assis",
    "Dips barres parallèles",
    "Crunch poulie haute",
    "Relevé de jambes suspendu"
  ]},
  B: { label:"Séance B : Bras + Abdos", ex:[
    "Curl poulie basse",
    "Tractions supination",
    "Extensions trichées",
    "Dips triceps sur banc",
    "Crunch poulie haute",
    "Relevé de jambes suspendu"
  ]},
  C: { label:"Séance C : Pecs + Bras + Abdos + Dos", ex:[
    "Développé machine convergente",
    "Curl marteau",
    "Dips triceps sur banc",
    "Tirage vertical/Tractions (dos)",
    "Crunch poulie haute",
    "Relevé de jambes suspendu"
  ]}
};

const MUSCLE_GROUP = {
  "Développé légèrement décliné": "pecs",
  "Écarté poulie vis-à-vis, assis": "pecs",
  "Dips barres parallèles": "pecs",
  "Développé machine convergente": "pecs",
  "Curl poulie basse": "bras",
  "Tractions supination": "bras",
  "Curl marteau": "bras",
  "Extensions trichées": "bras",
  "Dips triceps sur banc": "bras",
  "Tirage vertical/Tractions (dos)": "dos",
  "Crunch poulie haute": "abdos",
  "Relevé de jambes suspendu": "abdos"
};

const MUSCLE_LABEL = { pecs:"Pecs", bras:"Bras", abdos:"Abdos", dos:"Dos" };

const EXERCISE_CATEGORY = {
  "Développé légèrement décliné": "principal",
  "Écarté poulie vis-à-vis, assis": "isolation",
  "Dips barres parallèles": "principal",
  "Développé machine convergente": "principal",
  "Curl poulie basse": "principal",
  "Tractions supination": "principal",
  "Curl marteau": "isolation",
  "Extensions trichées": "isolation",
  "Dips triceps sur banc": "isolation",
  "Tirage vertical/Tractions (dos)": "dos",
  "Crunch poulie haute": "abdo",
  "Relevé de jambes suspendu": "abdo"
};

const SETS_BY_CATEGORY = {
  principal: { base:4, over:5 },
  isolation: { base:3, over:4 },
  abdo: { base:3, over:4 },
  dos: { base:3, over:3 }
};

function targetSets(exName, microKey){
  const cat = EXERCISE_CATEGORY[exName];
  const set = SETS_BY_CATEGORY[cat];
  return microKey === "over" ? set.over : set.base;
}

const EXERCISE_INFO = {
  "Développé légèrement décliné": {
    video: "https://www.youtube.com/watch?v=qq_bX5iw0HY&t=437s",
    steps: [
      "Régler le banc avec un léger angle décliné (10-20°)",
      "Amplitude complète, descente contrôlée jusqu'à la poitrine",
      "Remontée en poussant, sans verrouiller brutalement les coudes en haut"
    ]
  },
  "Écarté poulie vis-à-vis, assis": {
    video: "https://www.youtube.com/watch?v=qq_bX5iw0HY&t=235s",
    steps: [
      "S'asseoir entre les deux poulies pour une bonne stabilité (pas debout en marchant vers l'avant)",
      "Garder les coudes verrouillés et les omoplates serrées du début à la fin",
      "Ramener les poignées vers l'avant en gardant une légère flexion des coudes fixe",
      "Position des mains : plus haut pour cibler le haut des pecs, plus bas pour le bas des pecs"
    ]
  },
  "Dips barres parallèles": {
    video: "https://www.youtube.com/watch?v=qq_bX5iw0HY&t=437s",
    steps: [
      "Se pencher en avant sur toute la durée du mouvement (une position droite sollicite plus les triceps que les pecs)",
      "Descendre en amplitude complète si possible",
      "En cas de douleur au sternum/épaule, réduire légèrement l'amplitude plutôt que d'abandonner l'exercice",
      "Progresser la charge (lest) petit à petit"
    ]
  },
  "Développé machine convergente": {
    video: "https://www.youtube.com/watch?v=qq_bX5iw0HY&t=344s",
    steps: [
      "Choisir une machine à bonne courbe de résistance si possible (plus difficile en haut du mouvement qu'en bas)",
      "Position haute ou basse au choix (haut ou bas des pecs)",
      "Pousser en contrôlant le retour, sans à-coups"
    ]
  },
  "Extensions trichées": {
    video: "https://www.youtube.com/watch?v=cXNeX_t08wQ&t=506s",
    steps: [
      "Allongé sur un banc, haltères tendus au-dessus de la poitrine",
      "Phase 1 : fléchir les coudes pour amener les haltères vers le front",
      "Phase 2 : depuis cette position, continuer à ramener les haltères loin derrière la tête pour étirer la longue portion du triceps",
      "Revenir en sens inverse : ramener les coudes au niveau de la poitrine puis tendre les bras en extension complète",
      "Commencer léger pour apprivoiser la trajectoire avant d'augmenter la charge ; garder le mouvement contrôlé, sans inertie"
    ]
  },
  "Dips triceps sur banc": {
    video: "https://www.youtube.com/watch?v=cXNeX_t08wQ&t=391s",
    steps: [
      "Mains posées sur un banc derrière toi, jambes tendues devant (ou pliées pour réduire la difficulté)",
      "Poser des disques sur les cuisses pour charger",
      "Descendre en fléchissant les coudes, remonter en extension complète",
      "Ne pas surcharger au détriment de la qualité du mouvement"
    ]
  },
  "Curl poulie basse": {
    video: "https://www.youtube.com/watch?v=di2pTqQKdss&t=534s",
    steps: [
      "Se placer face à la poulie basse, bras tendus vers le bas",
