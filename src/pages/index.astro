const SEANCE_ORDER = ["A","B","C"];
const TOTAL_SESSIONS = 72;

let completedCount = 0;
let currentMicro = null;
let currentSeanceLetter = "A";
let restInterval = null;

function parseRestSeconds(restStr){
  const s = restStr.toLowerCase().replace(/\s+/g, '');
  const parts = s.split('-');
  const first = parts[0];
  const last = parts[parts.length - 1];
  const unit = last.includes('min') ? 'min' : (last.includes('sec') ? 'sec' : null);

  function toSeconds(token){
    let m = token.match(/^(\d+)min(\d+)?$/);
    if (m) return parseInt(m[1], 10) * 60 + (m[2] ? parseInt(m[2], 10) : 0);
    m = token.match(/^(\d+)sec$/);
    if (m) return parseInt(m[1], 10);
    m = token.match(/^(\d+)$/);
    if (m && unit) return unit === 'min' ? parseInt(m[1], 10) * 60 : parseInt(m[1], 10);
    return null;
  }

  const seconds = toSeconds(first);
  return seconds === null ? 60 : seconds;
}

function estimateSessionSeconds(seanceLetter, micro){
  const EXEC_PER_SET_SEC = 35;
  const TRANSITION_PER_EXERCISE_SEC = 60;
  const WARMUP_SEC = 300;
  const data = SEANCES[seanceLetter];
  const restSec = parseRestSeconds(micro.rest);
  const totalSets = data.ex.reduce((s, exName) => s + targetSets(exName, micro.key), 0);
  const nEx = data.ex.length;
  return WARMUP_SEC + totalSets * EXEC_PER_SET_SEC + (totalSets - 1) * restSec + nEx * TRANSITION_PER_EXERCISE_SEC;
}

function playBeep(){
  try{
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    [0, 0.3, 0.6].forEach((delay) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.frequency.value = 880;
      osc.connect(gain);
      gain.connect(ctx.destination);
      gain.gain.setValueAtTime(0.3, ctx.currentTime + delay);
      osc.start(ctx.currentTime + delay);
      osc.stop(ctx.currentTime + delay + 0.2);
    });
  }catch(e){}
}

function updateRestDisplay(remaining){
  const m = Math.floor(remaining / 60);
  const s = remaining % 60;
  document.getElementById('restTimeLeft').textContent = m + ":" + String(s).padStart(2, '0');
}

function stopRestTimer(){
  if (restInterval){ clearInterval(restInterval); restInterval = null; }
  document.getElementById('restTimer').classList.add('hidden');
}

function startRestTimer(seconds){
  stopRestTimer();
  let remaining = seconds;
  const bar = document.getElementById('restTimer');
  bar.classList.remove('hidden');
  updateRestDisplay(remaining);
  restInterval = setInterval(() => {
    remaining -= 1;
    if (remaining <= 0){
      clearInterval(restInterval);
      restInterval = null;
      document.getElementById('restTimeLeft').textContent = "Terminé !";
      if (navigator.vibrate) navigator.vibrate([200, 100, 200, 100, 200]);
      playBeep();
      setTimeout(() => bar.classList.add('hidden'), 3000);
      return;
    }
    updateRestDisplay(remaining);
  }, 1000);
}

document.getElementById('restSkipBtn').addEventListener('click', stopRestTimer);

function renderExerciseInfoBody(info){
  if (info.variants){
    return info.variants.map(v => `
      <div class="info-variant-name">${v.name}</div>
      <a class="info-video-link" href="${v.video}" target="_blank" rel="noopener">▶ Voir la vidéo</a>
      <ol class="info-steps">${v.steps.map(s => `<li>${s}</li>`).join('')}</ol>
    `).join('');
  }
  return `
    <a class="info-video-link" href="${info.video}" target="_blank" rel="noopener">▶ Voir la vidéo</a>
    <ol class="info-steps">${info.steps.map(s => `<li>${s}</li>`).join('')}</ol>
  `;
}

function showInfoSheet(title, bodyHtml){
  document.getElementById('infoSheetTitle').textContent = title;
  document.getElementById('infoSheetBody').innerHTML = bodyHtml;
  document.getElementById('exerciseInfoOverlay').classList.remove('hidden');
}

function openExerciseInfo(exName){
  const info = EXERCISE_INFO[exName];
  if (!info) return;
  showInfoSheet(exName, renderExerciseInfoBody(info));
}

function closeExerciseInfo(){
  document.getElementById('exerciseInfoOverlay').classList.add('hidden');
}

document.getElementById('infoCloseBtn').addEventListener('click', closeExerciseInfo);
document.getElementById('exerciseInfoOverlay').addEventListener('click', (e) => {
  if (e.target.id === 'exerciseInfoOverlay') closeExerciseInfo();
});

const MICRO_LEGEND = [
  {
    name:"Stress mécanique",
    objectif:"Maximiser la tension mécanique sur le muscle pour stimuler la force et la construction musculaire.",
    desc:"Répétitions courtes, récupérations longues, charges de travail élevées."
  },
  {
    name:"Stress métabolique",
    objectif:"Accumuler de la fatigue métabolique (\"la brûlure\") pour stimuler la croissance musculaire par une voie complémentaire à la tension pure.",
    desc:"Répétitions longues, récupérations courtes, charges de travail modérées."
  },
  {
    name:"Overreaching",
    objectif:"Pousser volontairement le volume et l'intensité au maximum pour déclencher un stress suffisant avant récupération, et progresser par surcompensation.",
    desc:"Plus de volume d'entraînement, plus d'intensité de travail, techniques d'intensification."
  }
];

function openMicroLegend(){
  const body = MICRO_LEGEND.map(m => `
    <div class="info-variant-name">${m.name}</div>
    <p style="margin:0 0 6px; font-size:13px; line-height:1.6;"><strong>Objectif</strong> : ${m.objectif}</p>
    <p style="margin:0 0 4px; font-size:13px; line-height:1.6;"><strong>Concrètement</strong> : ${m.desc}</p>
  `).join('');
  showInfoSheet("Types de microcycle", body);
}

document.getElementById('microInfoBtn').addEventListener('click', openMicroLegend);

function getWeekFromCount(count){
  const nextIndex = count + 1;
  let week = Math.ceil(nextIndex / 3);
  if (week > 24) week = 24;
  if (week < 1) week = 1;
  return week;
}

function getPosition(week){
  const meso = PROGRAM.find(m => week >= m.start && week <= m.end);
  const micro = meso.micro.find(mc => week >= mc.w[0] && week <= mc.w[1]);
  return { meso, micro };
}

function renderBar(week){
  const bar = document.getElementById('weekBar');
  bar.innerHTML = "";
  for(let w=1; w<=24; w++){
    const pos = getPosition(w);
    const seg = document.createElement('div');
    seg.className = "seg " + pos.micro.key;
    if (w < week || (w === week)) seg.classList.add('done');
    if (w === week) seg.classList.add('current');
    bar.appendChild(seg);
  }
}

async function loadCount(){
  try{
    const { data, error } = await supabase
      .from('progress')
      .select('completed_count')
      .eq('id', 1)
      .single();
    if (error || !data) return 0;
    return data.completed_count;
  }catch(e){ return 0; }
}

async function saveCount(val){
  try{
    const { error } = await supabase
      .from('progress')
      .update({ completed_count: val })
      .eq('id', 1);
    return !error;
  }catch(e){ return false; }
}

function render(){
  if (completedCount >= TOTAL_SESSIONS){
    document.getElementById('activeZone').classList.add('hidden');
    document.getElementById('macroDone').classList.remove('hidden');
  } else {
    document.getElementById('activeZone').classList.remove('hidden');
    document.getElementById('macroDone').classList.add('hidden');
  }

  const week = getWeekFromCount(Math.min(completedCount, TOTAL_SESSIONS - 1));
  const pos = getPosition(week);
  currentMicro = pos.micro;

  const nextIndex = completedCount + 1;
  currentSeanceLetter = SEANCE_ORDER[(nextIndex - 1) % 3];

  document.getElementById('weekNum').textContent = week + " / 24";
  document.getElementById('sessionCount').textContent = completedCount + " / " + TOTAL_SESSIONS + " séances validées";
  document.getElementById('mesoIndex').textContent = "Mésocycle " + (PROGRAM.indexOf(pos.meso) + 1);
  document.getElementById('mesoPhase').textContent = pos.meso.name + " — Semaines " + pos.meso.start + "–" + pos.meso.end;

  document.getElementById('microDot').className = "micro-dot " + pos.micro.key;
  document.getElementById('microName').textContent = pos.micro.name;
  document.getElementById('microDetail').textContent = pos.micro.reps + " reps · repos " + pos.micro.rest;
  document.getElementById('microNote').textContent = pos.micro.note || "";

  renderBar(week);

  if (completedCount < TOTAL_SESSIONS){
    document.getElementById('nextSeanceLabel').textContent = SEANCES[currentSeanceLetter].label;
    const estMin = Math.round(estimateSessionSeconds(currentSeanceLetter, pos.micro) / 60);
    document.getElementById('nextSeanceDuration').textContent = "~" + estMin + " min estimées";
    renderExercises();
  }
}

async function getLastLog(exName){
  try{
    const { data, error } = await supabase
      .from('exercise_logs')
      .select('poids, reps, date, target_reps, target_rest')
      .eq('exercise_name', exName)
      .order('date', { ascending: false })
      .order('created_at', { ascending: false })
      .limit(1)
      .maybeSingle();
    if (error || !data) return null;
    return data;
  }catch(e){ return null; }
}

async function saveLog(exName, poids, reps, seance, targetReps, targetRest){
  try{
    const { error } = await supabase
      .from('exercise_logs')
      .insert({
        exercise_name: exName,
        date: new Date().toISOString().slice(0,10),
        poids,
        reps,
        seance,
        target_reps: targetReps,
        target_rest: targetRest
      });
    return !error;
  }catch(e){ return false; }
}

async function getTodaySetCount(exName, seance){
  try{
    const today = new Date().toISOString().slice(0,10);
    const { count, error } = await supabase
      .from('exercise_logs')
      .select('*', { count: 'exact', head: true })
      .eq('exercise_name', exName)
      .eq('seance', seance)
      .eq('date', today);
    if (error) return 0;
    return count || 0;
  }catch(e){ return 0; }
}

async function renderExercises(){
  const container = document.getElementById('exList');
  const data = SEANCES[currentSeanceLetter];
  container.innerHTML = "";

  for(const exName of data.ex){
    const card = document.createElement('div');
    card.className = "ex-card";
    const last = await getLastLog(exName);
    let doneSets = await getTodaySetCount(exName, currentSeanceLetter);
    const goalSets = targetSets(exName, currentMicro.key);
    const muscle = MUSCLE_GROUP[exName];

    const hasInfo = !!EXERCISE_INFO[exName];

    card.innerHTML = `
      <div class="ex-head">
        <div>
          <div class="ex-name">${exName}</div>
          <div class="ex-meta-row">
            <span class="ex-muscle ${muscle}">${MUSCLE_LABEL[muscle]}</span>
            ${hasInfo ? '<button type="button" class="ex-info-btn">ⓘ Infos</button>' : ''}
          </div>
        </div>
        <div class="ex-target">${currentMicro.reps} reps<br>repos ${currentMicro.rest}<span class="ex-sets-counter">${doneSets}/${goalSets} séries</span></div>
      </div>
      <div class="ex-inputs">
        <div class="field"><input type="number" placeholder="kg" class="w-input" inputmode="decimal" value="${last ? last.poids : ''}"></div>
        <div class="field"><input type="number" placeholder="reps" class="r-input" inputmode="numeric" value="${last ? last.reps : ''}"></div>
        <button class="ex-save">✓ Fait</button>
      </div>
      <div class="ex-saved-flash">✓ Série enregistrée</div>
      <div class="ex-error-flash">Valeurs manquantes</div>
    `;

    const wInput = card.querySelector('.w-input');
    const rInput = card.querySelector('.r-input');
    const saveBtn = card.querySelector('.ex-save');
    const flash = card.querySelector('.ex-saved-flash');
    const errorFlash = card.querySelector('.ex-error-flash');
    const infoBtn = card.querySelector('.ex-info-btn');
    const setsCounter = card.querySelector('.ex-sets-counter');
    if (infoBtn) infoBtn.addEventListener('click', () => openExerciseInfo(exName));

    saveBtn.addEventListener('click', async () => {
      const poids = parseFloat(wInput.value);
      const reps = parseInt(rInput.value, 10);
      if(!poids || !reps){
        errorFlash.style.display = "block";
        setTimeout(() => { errorFlash.style.display = "none"; }, 2000);
        return;
      }
      saveBtn.textContent = "...";
      const ok = await saveLog(exName, poids, reps, currentSeanceLetter, currentMicro.reps, currentMicro.rest);
      if(ok){
        doneSets += 1;
        setsCounter.textContent = doneSets + "/" + goalSets + " séries";
        flash.style.display = "block";
        setTimeout(() => { flash.style.display = "none"; }, 2000);
        startRestTimer(parseRestSeconds(currentMicro.rest));
      }
      saveBtn.textContent = "✓ Fait";
    });

    container.appendChild(card);
  }
}

document.getElementById('validateBtn').addEventListener('click', async () => {
  if (completedCount >= TOTAL_SESSIONS) return;
  completedCount += 1;
  const ok = await saveCount(completedCount);
  if(!ok){ completedCount -= 1; alert("Erreur d'enregistrement, réessaie."); return; }
  stopRestTimer();
  render();
});

document.getElementById('settingsBtn').addEventListener('click', () => {
  document.getElementById('manualCount').value = completedCount;
  document.getElementById('settingsPanel').classList.remove('hidden');
});
document.getElementById('closeSettingsBtn').addEventListener('click', () => {
  document.getElementById('settingsPanel').classList.add('hidden');
});
document.getElementById('saveCountBtn').addEventListener('click', async () => {
  let val = parseInt(document.getElementById('manualCount').value, 10);
  if(isNaN(val)) return;
  if(val < 0) val = 0;
  if(val > 72) val = 72;
  const ok = await saveCount(val);
  if(ok){
    completedCount = val;
    document.getElementById('settingsPanel').classList.add('hidden');
    render();
  }
});
document.getElementById('undoBtn').addEventListener('click', async () => {
  if(completedCount <= 0) return;
  const val = completedCount - 1;
  const ok = await saveCount(val);
  if(ok){
    completedCount = val;
    document.getElementById('manualCount').value = completedCount;
    render();
  }
});

async function init(){
  completedCount = await loadCount();
  render();
}

init();
</script>
